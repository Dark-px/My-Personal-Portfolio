# Supabase Configuration
# Copy this file to .env and fill in your values

# Your Supabase Proxy URL (includes project_id)
VITE_SUPABASE_URL=https://api.your-domain.com/functions/v1/proxy/YOUR_PROJECT_ID

# Your Supabase Anon Key (public, safe to expose)
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# API Base URL and Project ID (used by shop & blog services)
VITE_API_URL=https://api.your-domain.com
VITE_PROJECT_ID=YOUR_PROJECT_ID

# Medium integration (optional but recommended)
VITE_MEDIUM_USERNAME=your-medium-username
VITE_MEDIUM_FEATURED_POST_1=
VITE_MEDIUM_FEATURED_POST_2=
VITE_MEDIUM_FEATURED_POST_3=

# Get these values from your admin panel at:
# https://admin.your-domain.com → Your Project → Settings
