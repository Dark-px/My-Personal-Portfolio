+.amatic-sc-regular {
+    font-family: "Amatic SC", sans-serif;
+    font-weight: 400;
+    font-style: normal;
+    font-size: 48px;
+}
+
+.amatic-sc-bold {
+    font-family: "Amatic SC", sans-serif;
+    font-weight: 700;
+    font-style: normal;
+    font-size: 80px;
+    color: white;
+}
+
+
+body {
+    background-image: url("wall.jpeg");
+    background-size: cover;
+    background-color: #303030;
+    text-align: center;
+}
+
+h1 {
+    color: #333;
+}
+
+
+.gallery-container {
+    display: flex;
+    flex-wrap: wrap;
+    justify-content: center;
+    padding: 10px;
+}
+
+.gallery-item {
+
+    margin: 10px;
+    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
+    width: 90%;
+}
+
+.gallery-item img {
+    width: 100%;
+    display: block;
+    border-radius: 15px;
+    transition: all 0.3s ease;
+}
+
+
+.gallery-item img:hover {
+    border: 2px solid #007BFF;
+    transform: scale(1.05);
+}
+
+
+@media (min-width: 768px) {
+    .gallery-item {
+        width: 45%;
+    }
+}
+
+@media (min-width: 992px) {
+    .gallery-item {
+        width: 30%;
+    }
